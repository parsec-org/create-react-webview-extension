{
  "name": "react-webview-extension",
  "displayName": "React Webview Extension",
  "description": "A VS Code extension template with React webview, RPC communication, and Tailwind CSS",
  "version": "0.0.1",
  "publisher": "your-publisher",
  "icon": "assets/vite.png",
  "type": "module",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:reactWebviewView"
  ],
  "license": "MIT",
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "react-webview",
          "title": "React Webview",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "react-webview": [
        {
          "type": "webview",
          "id": "reactWebviewView",
          "name": "Webview",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "react-webview.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:webview && npm run build",
    "dev:webview": "vite",
    "build:webview": "vite build",
    "build": "node esbuild.config.mjs",
    "compile": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json",
    "watch": "node esbuild.config.mjs --watch",
    "pretest": "npm run compile && npm run lint",
    "package": "vsce package --no-dependencies --allow-missing-repository",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vscode-test",
    "test:webview": "vitest run",
    "test:webview:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/QiyuanChen02/react-webview.git"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitejs/plugin-react-swc": "^4.2.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "react-icons": "^5.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.2",
    "vite": "^7.2.2",
    "vitest": "^3.2.1"
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/inter": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.90.11",
    "@webview-rpc/client": "^1.0.17",
    "@webview-rpc/host": "^1.0.17",
    "@webview-rpc/react-query": "^1.0.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.18.0",
    "semver": "^7.8.5",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.13"
  }
}
